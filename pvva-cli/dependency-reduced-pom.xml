<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <parent>
    <artifactId>pvva-root</artifactId>
    <groupId>io.github.plovdev</groupId>
    <version>${revision}</version>
  </parent>
  <modelVersion>4.0.0</modelVersion>
  <artifactId>pvva-cli</artifactId>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <transformers>
                <transformer>
                  <mainClass>org.plovdev.pvvacli.Main</mainClass>
                </transformer>
                <transformer />
              </transformers>
              <createSourcesJar>false</createSourcesJar>
              <shadedArtifactAttached>false</shadedArtifactAttached>
              <minimizeJar>false</minimizeJar>
              <finalName>pvva-cli</finalName>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <properties>
    <maven.compiler.target>25</maven.compiler.target>
    <slf4j.version>2.0.17</slf4j.version>
    <maven.compiler.source>25</maven.compiler.source>
    <keyer.version>1.7-beta</keyer.version>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <commaidle.version>1.3.1</commaidle.version>
    <maven.deploy.skip>true</maven.deploy.skip>
  </properties>
</project>
